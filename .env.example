# GitHub App ID (Settings → Developer settings → GitHub Apps → your app → "App ID")
APP_ID=123456

# GitHub App private key (PEM). Paste the full key. When set via a hosting
# provider's env UI, newlines may be stored as literal \n — that is handled.
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# Webhook secret configured in the GitHub App settings, used to verify payloads
WEBHOOK_SECRET=

# OpenRouter API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Optional: model to use for review (default: anthropic/claude-sonnet-4)
OPENROUTER_MODEL=anthropic/claude-sonnet-4
